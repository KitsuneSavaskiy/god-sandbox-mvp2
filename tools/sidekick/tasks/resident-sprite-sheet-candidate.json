{
  "schemaVersion": "godsandbox-task-recipe/v0",
  "taskId": "resident-sprite-sheet-candidate",
  "description": "Generate a resident sprite sheet candidate from a character portrait and validate it.",
  "nonTechnicalUserInputs": ["slug", "portrait"],
  "autoGeneratedFields": ["characterId", "assetBundleId", "worldDirectoryName", "jobId", "createdAt"],
  "steps": [
    {
      "id": "intake",
      "type": "cli",
      "command": "npm run sidekick:intake -- --slug {{slug}} --portrait {{portrait}}",
      "description": "Compose job JSON, set up incoming folder, copy portrait reference.",
      "producedPaths": [
        ".godsandbox/jobs/{{jobId}}.json",
        "assets/generated/residents/{{slug}}/incoming/",
        "assets/generated/residents/{{slug}}/reference/{{slug}}-portrait-reference-*.png"
      ]
    },
    {
      "id": "external-generation",
      "type": "external-ui",
      "description": "Generate sprite sheet using Codex pet or approved external subscription UI.",
      "promptRef": ".prompts/resident-sprites/{{slug}}.md",
      "portraitRef": "assets/generated/residents/{{slug}}/reference/{{slug}}-portrait-reference-*.png",
      "expectedOutput": "assets/generated/residents/{{slug}}/incoming/<sprite-sheet>.png",
      "generationStepUnavailableAction": "stop and report 'generation step unavailable'",
      "prohibited": [
        "Do not use portrait as sprite sheet",
        "Do not create a local synthetic or handmade sprite sheet",
        "Do not treat any image as a candidate if Codex pet / external UI was not used"
      ]
    },
    {
      "id": "sprite-check",
      "type": "cli",
      "command": "npm run sprite:check -- {{slug}}",
      "description": "Run the full validation suite (alpha, grid, visual audit).",
      "blockers": ["TOP", "BOT", "BOUND", "alpha check fail", "validate fail", "visual audit fail (exit code 1)"],
      "note": "Visual audit warnings (exit code 0) are heuristic hints for human review, not blockers."
    },
    {
      "id": "human-review",
      "type": "manual",
      "description": "Human reviewer confirms contact sheet and sandbox display fit.",
      "artifacts": [
        "assets/residents/{{slug}}/sprites/resident-sprite-sheet.visual-audit.svg",
        "assets/residents/{{slug}}/sprites/resident-sprite-sheet.visual-audit.json"
      ]
    },
    {
      "id": "po-visual-review",
      "type": "manual",
      "description": "PO confirms character identity and sandbox size fit. Required before ready promotion.",
      "gateCondition": "human-review passed"
    }
  ],
  "readyPromotionGate": {
    "required": ["sprite-check passed", "human-review confirmed", "po-visual-review confirmed"],
    "forbidden": ["Do not promote before PO visual confirmation"],
    "promotionTarget": "public/art/characters/defaults/{{slug}}/sprites/resident-sprite-sheet.png"
  },
  "spec": "docs/operations/resident-sprite-spec.md"
}
