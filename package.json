{
  "name": "god-sandbox-mvp2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "test:domain": "tsc --ignoreConfig --module NodeNext --moduleResolution NodeNext --target ES2022 --lib ES2022,DOM --strict --skipLibCheck --rootDir src --outDir node_modules/.tmp/domain-test-dist src/domain/runtime.test.ts && node node_modules/.tmp/domain-test-dist/domain/runtime.test.js",
    "test:ai": "tsc --ignoreConfig --module NodeNext --moduleResolution NodeNext --target ES2022 --lib ES2022,DOM --strict --skipLibCheck --rootDir src --outDir node_modules/.tmp/ai-test-dist src/ai/evaluation/ryo_reaction_eval.ts && node node_modules/.tmp/ai-test-dist/ai/evaluation/ryo_reaction_eval.js",
    "app:manual-sweep": "vite --host 127.0.0.1 --port 5173 --open /sandbox?mode=manual-sweep",
    "sprint9:dispatch": "node tools/sprint9-dispatch/dispatch.mjs",
    "sprite:check": "node tools/asset-pipeline/check-sprite-suite.mjs",
    "sprite:fit": "node tools/asset-pipeline/evaluate-sprite-frame-fit.mjs",
    "sidekick:intake": "node tools/sidekick/sidekick-intake.mjs",
    "sidekick:resident:hatch-pet": "node tools/sidekick/resident-hatch-pet-wrapper.mjs",
    "sidekick:watch": "node tools/sidekick/job-watcher.mjs",
    "sidekick:event-image": "node tools/sidekick/event-image-request.mjs",
    "security:git-boundary": "node tools/security/check-git-boundary.mjs --base origin/main",
    "security:pr-text": "node tools/security/check-pr-text-boundary.mjs",
    "assetgen:server": "node tools/app-server/asset-generation-server.mjs",
    "assetgen:guard": "node tools/security/check-no-image-api-key-usage.mjs",
    "assetgen:intake": "node tools/sidekick/character-asset-bundle-intake.mjs",
    "assetgen:expressions": "node tools/sidekick/portrait-expression-intake.mjs",
    "assetgen:derive-icon": "node tools/sidekick/derive-icon-from-sprite.mjs",
    "assetgen:test": "node tools/app-server/test-dry-run.mjs",
    "assetgen:review-pack": "node tools/sidekick/build-asset-review-pack.mjs",
    "assetgen:contracts": "node tools/asset-contracts/print-contracts.mjs",
    "assetgen:validate-contract": "node tools/asset-pipeline/validate-asset-contract.mjs"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
